{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifesession.dev/schemas/event.schema.json",
  "title": "Event",
  "type": "object",
  "required": ["id", "session_id", "type", "created_at", "payload"],
  "properties": {
    "id": {"type": "string"},
    "session_id": {"type": "string"},
    "type": {"type": "string"},
    "source": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "payload": {"type": "object"}
  },
  "additionalProperties": false
}
