{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifesession.dev/schemas/decision.schema.json",
  "title": "Decision",
  "type": "object",
  "required": ["id", "session_id", "status", "summary", "created_at"],
  "properties": {
    "id": {"type": "string"},
    "session_id": {"type": "string"},
    "status": {"enum": ["proposed", "approved", "rejected", "needs_review"]},
    "summary": {"type": "string"},
    "rationale": {"type": "string"},
    "created_by": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "evidence": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
